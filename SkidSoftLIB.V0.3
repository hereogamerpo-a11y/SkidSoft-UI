--  NOTIFICATIONS
-- ─────────────────────────────────────────────────────────
local notifHolder

local function initNotifs(sg)
    notifHolder = mk("Frame", sg, {
        Name                 = "Notifs",
        Size                 = UDim2.fromOffset(270, 10),
        Position             = UDim2.new(1, -282, 1, -12),
        AnchorPoint          = Vector2.new(0, 1),
        BackgroundTransparency = 1,
        AutomaticSize        = Enum.AutomaticSize.Y,
    })
    local ll = mk("UIListLayout", notifHolder, {
        FillDirection       = Enum.FillDirection.Vertical,
        VerticalAlignment   = Enum.VerticalAlignment.Bottom,
        HorizontalAlignment = Enum.HorizontalAlignment.Left,
        Padding             = UDim.new(0, 6),
        SortOrder           = Enum.SortOrder.LayoutOrder,
    })
end

function SS:Notify(cfg)
    if not notifHolder then return end
    cfg = cfg or {}
    local barCol = ({
        success = TH.Success,
        warning = TH.Warning,
        error   = TH.Danger,
    })[cfg.Type] or TH.Accent

    local card = mk("Frame", notifHolder, {
        Size             = UDim2.fromOffset(270, 56),
        BackgroundColor3 = Color3.fromRGB(13, 18, 30),
    })
    corner(card, 8)
    stroke(card, TH.Border, 1)

    mk("Frame", card, {
        Size             = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = barCol,
        BorderSizePixel  = 0,
    })
    mk("TextLabel", card, {
        Size               = UDim2.new(1, -14, 0, 18),
        Position           = UDim2.fromOffset(11, 9),
        BackgroundTransparency = 1,
        Text               = cfg.Title or "Notice",
        Font               = Enum.Font.GothamBold,
        TextSize           = 13,
        TextColor3         = TH.Text,
        TextXAlignment     = Enum.TextXAlignment.Left,
    })
    mk("TextLabel", card, {
        Size               = UDim2.new(1, -14, 0, 20),
        Position           = UDim2.fromOffset(11, 30),
        BackgroundTransparency = 1,
        Text               = cfg.Desc or "",
        Font               = Enum.Font.Gotham,
        TextSize           = 11,
        TextColor3         = TH.TextSub,
        TextXAlignment     = Enum.TextXAlignment.Left,
        TextWrapped        = true,
    })

    card.Position = UDim2.new(1, 10, 0, 0)
    tw(card, { Position = UDim2.new(0, 0, 0, 0) }, 0.2)
    task.delay(cfg.Duration or 4, function()
        tw(card, { Position = UDim2.new(1, 10, 0, 0) }, 0.2)
        task.delay(0.22, function() card:Destroy() end)
    end)
end

