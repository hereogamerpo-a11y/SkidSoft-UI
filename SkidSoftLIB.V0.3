        Size               = UDim2.fromOffset(160, 24),
        Position           = UDim2.fromOffset(156, 9),
        BackgroundTransparency = 1,
        Text               = (cfg.Game or "") .. "  ·  " .. (cfg.Version or "v1.0"),
        Font               = Enum.Font.Gotham,
        TextSize           = 11,
        TextColor3         = T.TextDark,
        TextXAlignment     = Enum.TextXAlignment.Left,
        ZIndex             = 3,
        Parent             = Topbar,
    })

    -- ── Quick Tab Bar (topbar center)
    local QuickBar = Create("Frame", {
        Size        = UDim2.new(0, 370, 0, 28),
        Position    = UDim2.new(0.5, -185, 0.5, -14),
        BackgroundTransparency = 1,
        ZIndex      = 3,
        Parent      = Topbar,
    })
