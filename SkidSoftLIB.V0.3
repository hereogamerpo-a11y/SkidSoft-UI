function SS:Notify(cfg)
    cfg = cfg or {}
    local barCol = ({ success = T.Success, warning = T.Warning, error = T.Danger })[cfg.Type] or T.Accent

    -- Orion-style: RoundFrame as card
    local card = Create("Frame", {
        Size             = UDim2.new(1, 0, 0, 58),
        BackgroundColor3 = Color3.fromRGB(12, 17, 28),
        BorderSizePixel  = 0,
        Parent           = NotifHolder,
    })
    MakeCorner(card, 8)
    MakeStroke(card, T.Stroke, 1)

    Create("Frame", {
        Size             = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = barCol,
        BorderSizePixel  = 0,
        Parent           = card,
    })
    Create("TextLabel", {
        Size               = UDim2.new(1, -14, 0, 18),
        Position           = UDim2.fromOffset(11, 9),
        BackgroundTransparency = 1,
        Text               = cfg.Title or "Notice",
        Font               = Enum.Font.GothamBold,
        TextSize           = 13,
        TextColor3         = T.Text,
        TextXAlignment     = Enum.TextXAlignment.Left,
        Parent             = card,
    })
    Create("TextLabel", {
        Size               = UDim2.new(1, -14, 0, 22),
        Position           = UDim2.fromOffset(11, 30),
        BackgroundTransparency = 1,
        Text               = cfg.Desc or "",
        Font               = Enum.Font.Gotham,
        TextSize           = 11,
        TextColor3         = T.TextDark,
        TextXAlignment     = Enum.TextXAlignment.Left,
        TextWrapped        = true,
        Parent             = card,
    })

    card.Position = UDim2.new(1, 20, 0, 0)
    Tween(card, { Position = UDim2.new(0, 0, 0, 0) }, 0.22)
    task.delay(cfg.Duration or 4, function()
        Tween(card, { Position = UDim2.new(1, 20, 0, 0) }, 0.22)
        task.delay(0.25, function() card:Destroy() end)
    end)
end

