        BackgroundTransparency = 1,
        RichText           = true,
        Text               = "Skid<font color='#60a5fa'>Soft</font>",
        Font               = Enum.Font.GothamBold,
        TextSize           = 15,
        TextColor3         = T.Text,
        TextXAlignment     = Enum.TextXAlignment.Left,
        ZIndex             = 3,
        Parent             = Topbar,
    })
    -- game · version label
