    local btnRow = Create("Frame", {
        Size             = UDim2.new(1, -40, 0, 34),
        Position         = UDim2.new(0, 20, 0, 198),
        BackgroundTransparency = 1,
        ZIndex           = 22,
        Parent           = panel,
    })
    Create("UIListLayout", {
        FillDirection       = Enum.FillDirection.Horizontal,
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        VerticalAlignment   = Enum.VerticalAlignment.Center,
        Padding             = UDim.new(0, 10),
        Parent              = btnRow,
    })

    local function SideBtn(txt)
        local b = Create("TextButton", {
            Size             = UDim2.fromOffset(126, 34),
            BackgroundColor3 = Color3.fromRGB(15, 22, 38),
            Text             = txt,
            Font             = Enum.Font.GothamSemibold,
            TextSize         = 13,
            TextColor3       = T.Text,
            AutoButtonColor  = false,
            BorderSizePixel  = 0,
            ZIndex           = 23,
            Parent           = btnRow,
        })
        MakeCorner(b, 7)
        MakeStroke(b, T.Stroke, 1)
        b.MouseEnter:Connect(function() Tween(b, { BackgroundColor3 = Color3.fromRGB(24, 38, 68) }, 0.1) end)
        b.MouseLeave:Connect(function() Tween(b, { BackgroundColor3 = Color3.fromRGB(15, 22, 38) }, 0.1) end)
        return b
    end

    local getKeyBtn  = SideBtn("Get Key")
    local discordBtn = SideBtn("Join Discord")

    -- Continue button
    local contBtn = Create("TextButton", {
        Size             = UDim2.new(1, -40, 0, 36),
        Position         = UDim2.new(0, 20, 0, 244),
        BackgroundColor3 = T.Accent,
        Text             = "Continue  →",
        Font             = Enum.Font.GothamBold,
        TextSize         = 14,
        TextColor3       = Color3.new(1, 1, 1),
        AutoButtonColor  = false,
        BorderSizePixel  = 0,
        ZIndex           = 22,
        Parent           = panel,
    })
    MakeCorner(contBtn, 7)
    contBtn.MouseEnter:Connect(function() Tween(contBtn, { BackgroundColor3 = T.AccentHi }, 0.1) end)
    contBtn.MouseLeave:Connect(function() Tween(contBtn, { BackgroundColor3 = T.Accent   }, 0.1) end)

    -- Logic
    getKeyBtn.MouseButton1Click:Connect(function()
        if cfg.GetKeyURL then
            pcall(setclipboard, cfg.GetKeyURL)
            statusLbl.TextColor3 = T.Warning
            statusLbl.Text = "Link kopiert!"
            task.delay(2, function() statusLbl.Text = "" end)
        end
    end)
    discordBtn.MouseButton1Click:Connect(function()
        if cfg.DiscordURL then
            pcall(setclipboard, cfg.DiscordURL)
            statusLbl.TextColor3 = T.Warning
            statusLbl.Text = "Discord Link kopiert!"
            task.delay(2, function() statusLbl.Text = "" end)
        end
    end)

    local function TryKey()
        local val = (keyInput.Text or ""):gsub("%s+", ""):upper()
        if val == "" then
            statusLbl.TextColor3 = T.Danger
            statusLbl.Text = "Bitte gib einen Key ein."
            return
        end
        local ok = false
        for _, k in ipairs(cfg.Keys or {}) do
            if val == k:upper() then ok = true break end
        end
        if ok then
            statusLbl.TextColor3 = T.Success
            statusLbl.Text = "✓ Key akzeptiert!"
            task.delay(0.5, function()
                Tween(panel,   { BackgroundTransparency = 1 }, 0.28)
                Tween(overlay, { BackgroundTransparency = 1 }, 0.28)
                task.delay(0.32, function()
                    panel:Destroy()
                    overlay:Destroy()
                    onSuccess()
                end)
            end)
        else
            statusLbl.TextColor3 = T.Danger
            statusLbl.Text = "✗ Ungültiger Key."
            Tween(inputBG, { BackgroundColor3 = Color3.fromRGB(36, 12, 12) }, 0.08)
            task.delay(0.45, function()
                Tween(inputBG, { BackgroundColor3 = Color3.fromRGB(13, 19, 33) }, 0.18)
            end)
        end
    end

    contBtn.MouseButton1Click:Connect(TryKey)
    keyInput.FocusLost:Connect(function(enter) if enter then TryKey() end end)
end

