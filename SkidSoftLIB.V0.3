function SS:CreateWindow(cfg)
    cfg = cfg or {}
    T   = self.Theme

    local win = { _tabs = {}, _activeTab = nil, _open = true }

    -- ─────────────────────────────────────────
    --  MAIN WINDOW
    --  Orion's exact pattern:
    --    RoundFrame (BackgroundColor, UICorner child, ClipsDescendants=true)
    --    UIStroke child → renders OVER the clip, stays visible at all 4 corners
    -- ─────────────────────────────────────────
    local MainWindow = Create("Frame", {
        Name             = "SkidSoftWindow",
        Size             = UDim2.fromOffset(780, 500),
        Position         = UDim2.new(0.5, -390, 0.5, -250),
        BackgroundColor3 = T.Main,
        ClipsDescendants = true,    -- clips children → UICorner rounds them
        BorderSizePixel  = 0,
        Parent           = SkidGui,
    })
    MakeCorner(MainWindow, 10)   -- UICorner as direct child, same as Orion
    MakeStroke(MainWindow, T.Stroke, 1.5)  -- UIStroke as direct child, renders after clip

    -- ── Drag handle (transparent frame over topbar area)
    local DragPoint = Create("Frame", {
        Size             = UDim2.new(1, 0, 0, 42),
        BackgroundTransparency = 1,
        ZIndex           = 5,
        Parent           = MainWindow,
    })
    MakeDraggable(DragPoint, MainWindow)

    -- ── Topbar background
    local Topbar = Create("Frame", {
        Size             = UDim2.new(1, 0, 0, 42),
        BackgroundColor3 = T.Topbar,
        BorderSizePixel  = 0,
        ZIndex           = 2,
        Parent           = MainWindow,
    })
    -- Topbar bottom border line
    Create("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = T.Stroke,
        BorderSizePixel  = 0,
        Parent           = Topbar,
    })
    -- Subtle accent glow at very top
    Create("Frame", {
        Size             = UDim2.new(0, 300, 0, 1),
        Position         = UDim2.new(0.5, -150, 0, 0),
        BackgroundColor3 = T.Accent,
        BorderSizePixel  = 0,
        Parent           = Topbar,
    })

    -- ── Logo (left side of topbar)
    local logoBG = Create("Frame", {
        Size             = UDim2.fromOffset(24, 24),
        Position         = UDim2.fromOffset(12, 9),
        BackgroundColor3 = T.Accent,
        BorderSizePixel  = 0,
