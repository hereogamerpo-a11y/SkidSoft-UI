        -- Orion minimizes before destroy — we do a quick tween then destroy
        MainWindow.ClipsDescendants = true
        TweenService:Create(MainWindow, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
            { Size = UDim2.fromOffset(780, 0) }):Play()
        task.delay(0.32, function() MainWindow:Destroy() end)
    end)

    dotMin.MouseButton1Click:Connect(function()
