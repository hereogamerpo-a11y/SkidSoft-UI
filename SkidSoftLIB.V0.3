            MainWindow.ClipsDescendants = false
            TweenService:Create(MainWindow, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
                { Size = UDim2.fromOffset(780, 500) }):Play()
            task.delay(0.05, function() MainWindow.ClipsDescendants = true end)
        else
            MainWindow.ClipsDescendants = true
            TweenService:Create(MainWindow, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
                { Size = UDim2.fromOffset(780, 42) }):Play()
        end
    end)

    -- Toggle key
    UserInputService.InputBegan:Connect(function(i, gp)
        if gp then return end
        if i.KeyCode == (cfg.ToggleKey or Enum.KeyCode.Insert) then
            win._open = not win._open
            if win._open then
                MainWindow.ClipsDescendants = false
                TweenService:Create(MainWindow, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
                    { Size = UDim2.fromOffset(780, 500) }):Play()
                task.delay(0.05, function() MainWindow.ClipsDescendants = true end)
            else
                MainWindow.ClipsDescendants = true
                TweenService:Create(MainWindow, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
                    { Size = UDim2.fromOffset(780, 42) }):Play()
            end
        end
    end)

    -- ── Body (below topbar)
    local Body = Create("Frame", {
        Size             = UDim2.new(1, 0, 1, -42),
        Position         = UDim2.fromOffset(0, 42),
        BackgroundTransparency = 1,
        ZIndex           = 2,
        Parent           = MainWindow,
    })

    -- ── Sidebar
    local Sidebar = Create("ScrollingFrame", {
        Size                 = UDim2.new(0, 148, 1, 0),
        BackgroundColor3     = T.Sidebar,
        BorderSizePixel      = 0,
        ScrollBarThickness   = 2,
        ScrollBarImageColor3 = T.Stroke,
        CanvasSize           = UDim2.fromScale(0, 0),
        AutomaticCanvasSize  = Enum.AutomaticSize.Y,
        ClipsDescendants     = true,
        ZIndex               = 2,
        Parent               = Body,
    })
    MakeList(Sidebar, 3)
    MakePadding(Sidebar, 10, 8, 10, 8)

    -- Sidebar right border (on Body so it doesn't affect sidebar layout)
    Create("Frame", {
        Size             = UDim2.new(0, 1, 1, 0),
        Position         = UDim2.fromOffset(148, 0),
        BackgroundColor3 = T.Stroke,
        BorderSizePixel  = 0,
        ZIndex           = 3,
        Parent           = Body,
    })

    -- ── Content area
    local ContentArea = Create("Frame", {
        Size             = UDim2.new(1, -148, 1, 0),
        Position         = UDim2.fromOffset(148, 0),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        ZIndex           = 2,
        Parent           = Body,
    })

    -- ══════════════════════════════════════════
    --  ADD TAB
    -- ══════════════════════════════════════════
    function win:AddTab(tc)
        tc = tc or {}
        local name = tc.Name or "Tab"
        local tab  = { _name = name }

        -- Sidebar button (same pattern as Orion's TabFrame)
        local sbtn = Create("TextButton", {
            Size             = UDim2.new(1, 0, 0, 32),
            BackgroundColor3 = Color3.fromRGB(18, 30, 52),
            BackgroundTransparency = 1,
            Text             = "",
            AutoButtonColor  = false,
            BorderSizePixel  = 0,
            ZIndex           = 3,
            Parent           = Sidebar,
        })
        MakeCorner(sbtn, 7)

        local sLbl = Create("TextLabel", {
            Size               = UDim2.new(1, -14, 1, 0),
            Position           = UDim2.fromOffset(12, 0),
            BackgroundTransparency = 1,
            Text               = name,
            Font               = Enum.Font.GothamSemibold,
            TextSize           = 13,
            TextColor3         = T.TextDark,
            TextXAlignment     = Enum.TextXAlignment.Left,
            ZIndex             = 4,
            Parent             = sbtn,
        })

        -- Active indicator bar
        local sbar = Create("Frame", {
            Size             = UDim2.fromOffset(3, 16),
            Position         = UDim2.new(0, 0, 0.5, -8),
            BackgroundColor3 = T.Accent,
            BorderSizePixel  = 0,
            Visible          = false,
            ZIndex           = 4,
            Parent           = sbtn,
        })
        MakeCorner(sbar, 2)

        -- Quick tab button (topbar)
        local qbtn = Create("TextButton", {
            Size             = UDim2.fromOffset(0, 26),
            AutomaticSize    = Enum.AutomaticSize.X,
            BackgroundColor3 = Color3.fromRGB(18, 34, 62),
            BackgroundTransparency = 1,
            Text             = name,
            Font             = Enum.Font.GothamSemibold,
            TextSize         = 12,
            TextColor3       = T.TextDark,
            AutoButtonColor  = false,
            BorderSizePixel  = 0,
            ZIndex           = 4,
            Parent           = QuickBar,
        })
        MakePadding(qbtn, 0, 10, 0, 10)
        MakeCorner(qbtn, 5)

        -- Tab content (ScrollingFrame — same as Orion's Container)
        local tabFrame = Create("ScrollingFrame", {
            Size                 = UDim2.fromScale(1, 1),
            BackgroundTransparency = 1,
            ScrollBarThickness   = 3,
            ScrollBarImageColor3 = T.Stroke,
            BorderSizePixel      = 0,
            CanvasSize           = UDim2.fromScale(0, 0),
            AutomaticCanvasSize  = Enum.AutomaticSize.Y,
            Visible              = false,
            ZIndex               = 3,
            Parent               = ContentArea,
        })
        MakeList(tabFrame, 10)
        MakePadding(tabFrame, 16, 18, 16, 18)

        tab._frame = tabFrame
        tab._sbtn  = sbtn
        tab._qbtn  = qbtn

        -- ── Activate function (Orion-style: loop all, reset, then activate this)
        local function Activate()
            for _, t in ipairs(win._tabs) do
                t._frame.Visible = false

                t._sbtn.BackgroundTransparency = 1
                local tl = t._sbtn:FindFirstChildOfClass("TextLabel")
                if tl then tl.TextColor3 = T.TextDark end
                local tb = t._sbtn:FindFirstChildOfClass("Frame")
                if tb then tb.Visible = false end

                t._qbtn.TextColor3 = T.TextDark
                t._qbtn.BackgroundTransparency = 1
                local qs = t._qbtn:FindFirstChildOfClass("UIStroke")
                if qs then qs:Destroy() end
            end

            tabFrame.Visible = true
            sLbl.TextColor3  = T.AccentHi
            sbar.Visible     = true
            Tween(sbtn, { BackgroundColor3 = Color3.fromRGB(18, 30, 52), BackgroundTransparency = 0 }, 0.12)

            qbtn.TextColor3 = T.AccentHi
            Tween(qbtn, { BackgroundColor3 = Color3.fromRGB(18, 36, 70), BackgroundTransparency = 0 }, 0.1)
            MakeStroke(qbtn, Color3.fromRGB(38, 76, 148), 1)

            win._activeTab = tab
        end

        sbtn.MouseButton1Click:Connect(Activate)
        qbtn.MouseButton1Click:Connect(Activate)

        sbtn.MouseEnter:Connect(function()
            if win._activeTab ~= tab then
                Tween(sbtn, { BackgroundColor3 = Color3.fromRGB(14, 24, 44), BackgroundTransparency = 0 }, 0.1)
            end
        end)
        sbtn.MouseLeave:Connect(function()
            if win._activeTab ~= tab then
                Tween(sbtn, { BackgroundTransparency = 1 }, 0.1)
            end
        end)

        table.insert(win._tabs, tab)

        -- Auto-activate first tab immediately (synchronous, not deferred)
        if #win._tabs == 1 then
            Activate()
        end

        -- ══════════════════════════════════════
        --  ADD SECTION
        -- ══════════════════════════════════════
        function tab:AddSection(sc)
            sc = sc or {}
            local sec = {}

            -- Section card — Orion pattern: RoundFrame + ClipsDescendants=false
            -- We do NOT ClipsDescendants on the section card so its own UICorner shows
            local card = Create("Frame", {
                Size             = UDim2.new(1, 0, 0, 0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                BackgroundColor3 = T.Second,
                BorderSizePixel  = 0,
                ClipsDescendants = false,
                ZIndex           = 4,
                Parent           = tabFrame,
            })
            MakeCorner(card, 8)
            MakeStroke(card, T.Stroke, 1)
            MakePadding(card, 10, 12, 12, 12)

            local innerFrame = Create("Frame", {
                Size             = UDim2.new(1, 0, 0, 0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,
                ZIndex           = 4,
                Parent           = card,
            })
            MakeList(innerFrame, 0)

            -- Section header
            if sc.Name and sc.Name ~= "" then
                local hdr = Create("Frame", {
                    Size             = UDim2.new(1, 0, 0, 22),
                    BackgroundTransparency = 1,
                    ZIndex           = 5,
                    Parent           = innerFrame,
                })
                Create("TextLabel", {
                    Size               = UDim2.fromScale(1, 1),
                    BackgroundTransparency = 1,
                    Text               = sc.Name:upper(),
                    Font               = Enum.Font.GothamBold,
                    TextSize           = 10,
                    TextColor3         = T.TextDark,
                    TextXAlignment     = Enum.TextXAlignment.Left,
                    ZIndex             = 6,
                    Parent             = hdr,
                })
                Create("Frame", {
                    Size             = UDim2.new(1, 0, 0, 1),
                    BackgroundColor3 = T.Divider,
                    BorderSizePixel  = 0,
                    ZIndex           = 5,
                    Parent           = innerFrame,
                })
            end

            -- ── Control row helper
            local function MakeRow(labelTxt, subTxt)
                local h   = subTxt and 46 or 36
                local row = Create("Frame", {
                    Size             = UDim2.new(1, 0, 0, h),
                    BackgroundTransparency = 1,
                    ZIndex           = 5,
                    Parent           = innerFrame,
                })
                -- bottom divider
                Create("Frame", {
                    Size             = UDim2.new(1, 0, 0, 1),
                    Position         = UDim2.new(0, 0, 1, -1),
                    BackgroundColor3 = T.Divider,
                    BorderSizePixel  = 0,
                    ZIndex           = 5,
                    Parent           = row,
                })
                -- label side
                local ls = Create("Frame", {
                    Size             = UDim2.new(0.54, 0, 1, 0),
                    BackgroundTransparency = 1,
                    ZIndex           = 5,
                    Parent           = row,
                })
                Create("TextLabel", {
                    Size               = UDim2.new(1, 0, 0, 18),
                    Position           = UDim2.fromOffset(0, subTxt and 7 or 9),
                    BackgroundTransparency = 1,
                    Text               = labelTxt or "",
                    Font               = Enum.Font.GothamSemibold,
                    TextSize           = 13,
                    TextColor3         = T.Text,
                    TextXAlignment     = Enum.TextXAlignment.Left,
                    ZIndex             = 6,
                    Parent             = ls,
                })
                if subTxt then
                    Create("TextLabel", {
                        Size               = UDim2.new(1, 0, 0, 13),
                        Position           = UDim2.fromOffset(0, 26),
                        BackgroundTransparency = 1,
                        Text               = subTxt,
                        Font               = Enum.Font.Gotham,
                        TextSize           = 10,
                        TextColor3         = T.TextDark,
                        TextXAlignment     = Enum.TextXAlignment.Left,
                        ZIndex             = 6,
                        Parent             = ls,
                    })
                end
                -- control side
                local ca = Create("Frame", {
                    Size             = UDim2.new(0.46, 0, 1, 0),
                    Position         = UDim2.fromScale(0.54, 0),
                    BackgroundTransparency = 1,
                    ZIndex           = 5,
                    Parent           = row,
                })
                return row, ca
            end

            -- ════════════════════════════════
            --  TOGGLE
            -- ════════════════════════════════
            function sec:AddToggle(tc2)
                tc2 = tc2 or {}
                local v = tc2.Default == true
                if tc2.Flag then SS.Flags[tc2.Flag] = v end

                local _, ca = MakeRow(tc2.Name, tc2.Desc)

                local track = Create("Frame", {
                    Size             = UDim2.fromOffset(38, 20),
                    Position         = UDim2.new(1, -38, 0.5, -10),
                    BackgroundColor3 = v and T.Accent or T.ToggleOff,
                    BorderSizePixel  = 0,
                    ZIndex           = 6,
                    Parent           = ca,
                })
                MakeCorner(track, 10)
                local knob = Create("Frame", {
                    Size             = UDim2.fromOffset(14, 14),
                    Position         = UDim2.fromOffset(v and 21 or 3, 3),
                    BackgroundColor3 = v and Color3.new(1,1,1) or Color3.fromRGB(70,90,120),
                    BorderSizePixel  = 0,
                    ZIndex           = 7,
                    Parent           = track,
                })
                MakeCorner(knob, 7)

                local obj = { Value = v }
                local function Set(nv, noCall)
                    obj.Value = nv
                    if tc2.Flag then SS.Flags[tc2.Flag] = nv end
                    Tween(track, { BackgroundColor3 = nv and T.Accent or T.ToggleOff }, 0.15)
                    Tween(knob, {
                        Position         = UDim2.fromOffset(nv and 21 or 3, 3),
                        BackgroundColor3 = nv and Color3.new(1,1,1) or Color3.fromRGB(70,90,120),
                    }, 0.15)
                    if not noCall and tc2.Callback then pcall(tc2.Callback, nv) end
                end
                track.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then Set(not obj.Value) end
                end)
                function obj:Set(nv) Set(nv) end
                return obj
            end

            -- ════════════════════════════════
            --  SLIDER
            -- ════════════════════════════════
            function sec:AddSlider(sc2)
                sc2  = sc2 or {}
                local mn  = sc2.Min or 0
                local mx  = sc2.Max or 100
                local def = math.clamp(sc2.Default or mn, mn, mx)
                local suf = sc2.Suffix or ""
                if sc2.Flag then SS.Flags[sc2.Flag] = def end

                local _, ca = MakeRow(sc2.Name, sc2.Desc)

                local valLbl = Create("TextLabel", {
                    Size               = UDim2.fromOffset(44, 20),
                    Position           = UDim2.new(1, -44, 0.5, -10),
                    BackgroundTransparency = 1,
                    Text               = tostring(def) .. suf,
                    Font               = Enum.Font.GothamBold,
                    TextSize           = 12,
                    TextColor3         = T.AccentHi,
                    TextXAlignment     = Enum.TextXAlignment.Right,
                    ZIndex             = 6,
                    Parent             = ca,
                })
                local track = Create("Frame", {
                    Size             = UDim2.new(1, -52, 0, 4),
                    Position         = UDim2.new(0, 0, 0.5, -2),
                    BackgroundColor3 = T.SliderBG,
                    BorderSizePixel  = 0,
                    ClipsDescendants = true,
                    ZIndex           = 6,
                    Parent           = ca,
                })
                MakeCorner(track, 2)

                local p0   = (def - mn) / (mx - mn)
                local fill = Create("Frame", {
                    Size             = UDim2.new(p0, 0, 1, 0),
                    BackgroundColor3 = T.Accent,
                    BorderSizePixel  = 0,
                    ZIndex           = 7,
                    Parent           = track,
                })
                MakeCorner(fill, 2)
                local thumb = Create("Frame", {
                    Size             = UDim2.fromOffset(12, 12),
                    Position         = UDim2.new(p0, -6, 0.5, -6),
                    BackgroundColor3 = T.AccentHi,
                    BorderSizePixel  = 0,
                    ZIndex           = 8,
                    Parent           = track,
                })
                MakeCorner(thumb, 6)

                local obj  = { Value = def }
                local drag = false

                local function Apply(x)
                    local p = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    local vv = math.round(mn + (mx - mn) * p)
                    obj.Value      = vv
                    if sc2.Flag then SS.Flags[sc2.Flag] = vv end
                    fill.Size      = UDim2.new(p, 0, 1, 0)
                    thumb.Position = UDim2.new(p, -6, 0.5, -6)
                    valLbl.Text    = tostring(vv) .. suf
                    if sc2.Callback then pcall(sc2.Callback, vv) end
                end

                track.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true; Apply(i.Position.X) end
                end)
                track.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
                end)
                UserInputService.InputChanged:Connect(function(i)
                    if drag and i.UserInputType == Enum.UserInputType.MouseMovement then Apply(i.Position.X) end
                end)

                function obj:Set(nv)
                    nv = math.clamp(nv, mn, mx)
                    local p = (nv - mn) / (mx - mn)
                    obj.Value      = nv
                    if sc2.Flag then SS.Flags[sc2.Flag] = nv end
                    fill.Size      = UDim2.new(p, 0, 1, 0)
                    thumb.Position = UDim2.new(p, -6, 0.5, -6)
                    valLbl.Text    = tostring(nv) .. suf
                end
                return obj
            end

            -- ════════════════════════════════
            --  DROPDOWN
            -- ════════════════════════════════
            function sec:AddDropdown(dc)
                dc   = dc or {}
                local opts = dc.Options or {}
                local sel  = dc.Default or opts[1] or ""
                if dc.Flag then SS.Flags[dc.Flag] = sel end

                local _, ca = MakeRow(dc.Name)
                local isOpen = false

                local btnF = Create("TextButton", {
                    Size             = UDim2.new(1, 0, 0, 24),
                    Position         = UDim2.new(0, 0, 0.5, -12),
                    BackgroundColor3 = Color3.fromRGB(12, 20, 36),
                    Text             = "",
                    AutoButtonColor  = false,
                    BorderSizePixel  = 0,
                    ZIndex           = 6,
                    Parent           = ca,
                })
                MakeCorner(btnF, 5)
                MakeStroke(btnF, T.Stroke, 1)

                local btnLbl = Create("TextLabel", {
                    Size               = UDim2.new(1, -16, 1, 0),
                    Position           = UDim2.fromOffset(7, 0),
                    BackgroundTransparency = 1,
                    Text               = sel,
                    Font               = Enum.Font.GothamSemibold,
                    TextSize           = 11,
                    TextColor3         = T.Text,
                    TextXAlignment     = Enum.TextXAlignment.Left,
                    ZIndex             = 7,
                    Parent             = btnF,
                })
                Create("TextLabel", {
                    Size               = UDim2.fromOffset(14, 24),
                    Position           = UDim2.new(1, -14, 0, 0),
                    BackgroundTransparency = 1,
                    Text               = "▾",
                    Font               = Enum.Font.GothamBold,
                    TextSize           = 10,
                    TextColor3         = T.TextDark,
                    ZIndex             = 7,
                    Parent             = btnF,
                })

                -- Drop list at SkidGui level (avoids any clip issues)
                local dropList = Create("Frame", {
                    Size             = UDim2.fromOffset(100, 0),
                    BackgroundColor3 = Color3.fromRGB(9, 14, 24),
                    BorderSizePixel  = 0,
                    ClipsDescendants = true,
                    Visible          = false,
                    ZIndex           = 60,
                    Parent           = SkidGui,
                })
                MakeCorner(dropList, 6)
                MakeStroke(dropList, T.Stroke, 1)
                MakeList(dropList, 0)

                local obj2 = { Value = sel }
                local function Close()
                    isOpen = false
                    Tween(dropList, { Size = UDim2.fromOffset(dropList.AbsoluteSize.X, 0) }, 0.12)
                    task.delay(0.13, function() dropList.Visible = false end)
                end
                local function Open()
                    isOpen = true
                    local ap = btnF.AbsolutePosition
                    local as = btnF.AbsoluteSize
                    dropList.Size     = UDim2.fromOffset(as.X, 0)
                    dropList.Position = UDim2.fromOffset(ap.X, ap.Y + as.Y + 2)
                    dropList.Visible  = true
                    Tween(dropList, { Size = UDim2.fromOffset(as.X, #opts * 26) }, 0.15)
                end

                for _, opt in ipairs(opts) do
                    local ob = Create("TextButton", {
                        Size             = UDim2.new(1, 0, 0, 26),
                        BackgroundColor3 = Color3.fromRGB(18, 34, 62),
                        BackgroundTransparency = 1,
                        Text             = opt,
                        Font             = Enum.Font.Gotham,
                        TextSize         = 11,
                        TextColor3       = T.TextDark,
                        TextXAlignment   = Enum.TextXAlignment.Left,
                        AutoButtonColor  = false,
                        BorderSizePixel  = 0,
                        ZIndex           = 61,
                        Parent           = dropList,
                    })
                    MakePadding(ob, 0, 0, 0, 8)
                    ob.MouseEnter:Connect(function() Tween(ob, { BackgroundTransparency = 0 }, 0.1); ob.TextColor3 = T.Text end)
                    ob.MouseLeave:Connect(function() Tween(ob, { BackgroundTransparency = 1 }, 0.1); ob.TextColor3 = T.TextDark end)
                    ob.MouseButton1Click:Connect(function()
                        obj2.Value = opt; btnLbl.Text = opt
                        if dc.Flag then SS.Flags[dc.Flag] = opt end
                        if dc.Callback then pcall(dc.Callback, opt) end
                        Close()
                    end)
                end

                btnF.MouseButton1Click:Connect(function() if isOpen then Close() else Open() end end)
                function obj2:Set(v) obj2.Value = v; btnLbl.Text = v; if dc.Flag then SS.Flags[dc.Flag] = v end end
                return obj2
            end

            -- ════════════════════════════════
            --  BUTTON
            -- ════════════════════════════════
            function sec:AddButton(bc)
                bc = bc or {}
                local _, ca = MakeRow(bc.Name, bc.Desc)
                local btn = Create("TextButton", {
                    Size             = UDim2.fromOffset(78, 26),
                    Position         = UDim2.new(1, -78, 0.5, -13),
                    BackgroundColor3 = T.Accent,
                    Text             = "Execute",
                    Font             = Enum.Font.GothamBold,
                    TextSize         = 12,
                    TextColor3       = Color3.new(1, 1, 1),
                    AutoButtonColor  = false,
                    BorderSizePixel  = 0,
                    ZIndex           = 6,
                    Parent           = ca,
                })
                MakeCorner(btn, 5)
                btn.MouseEnter:Connect(function() Tween(btn, { BackgroundColor3 = T.AccentHi }, 0.1) end)
                btn.MouseLeave:Connect(function() Tween(btn, { BackgroundColor3 = T.Accent   }, 0.1) end)
                btn.MouseButton1Click:Connect(function()
                    Tween(btn, { BackgroundColor3 = T.AccentLo }, 0.06)
                    task.delay(0.1, function() Tween(btn, { BackgroundColor3 = T.Accent }, 0.12) end)
                    if bc.Callback then pcall(bc.Callback) end
                end)
                return btn
            end

            -- ════════════════════════════════
            --  TEXTBOX
            -- ════════════════════════════════
            function sec:AddTextBox(tbc)
                tbc = tbc or {}
                local _, ca = MakeRow(tbc.Name)
                local tbf = Create("Frame", {
                    Size             = UDim2.new(1, 0, 0, 24),
                    Position         = UDim2.new(0, 0, 0.5, -12),
                    BackgroundColor3 = Color3.fromRGB(12, 20, 36),
                    BorderSizePixel  = 0,
                    ZIndex           = 6,
                    Parent           = ca,
                })
                MakeCorner(tbf, 5)
                local tbs = MakeStroke(tbf, T.Stroke, 1)
                local tb  = Create("TextBox", {
                    Size               = UDim2.new(1, -8, 1, 0),
                    Position           = UDim2.fromOffset(4, 0),
                    BackgroundTransparency = 1,
                    Text               = tbc.Default     or "",
                    PlaceholderText    = tbc.Placeholder or "",
                    PlaceholderColor3  = T.TextDark,
                    Font               = Enum.Font.Gotham,
                    TextSize           = 11,
                    TextColor3         = T.Text,
                    ClearTextOnFocus   = false,
                    ZIndex             = 7,
                    Parent             = tbf,
                })
                tb.Focused:Connect(function()   Tween(tbs, { Color = T.Accent }, 0.15) end)
                tb.FocusLost:Connect(function()
                    Tween(tbs, { Color = T.Stroke }, 0.15)
                    if tbc.Flag     then SS.Flags[tbc.Flag] = tb.Text end
                    if tbc.Callback then pcall(tbc.Callback, tb.Text) end
                end)
                local obj3 = { Value = "" }
                function obj3:Set(v) tb.Text = v end
                return obj3
            end

            -- ════════════════════════════════
            --  LABEL
            -- ════════════════════════════════
            function sec:AddLabel(txt)
                return Create("TextLabel", {
                    Size               = UDim2.new(1, 0, 0, 20),
                    BackgroundTransparency = 1,
                    Text               = txt or "",
                    Font               = Enum.Font.Gotham,
                    TextSize           = 11,
                    TextColor3         = T.TextDark,
                    TextXAlignment     = Enum.TextXAlignment.Left,
                    TextWrapped        = true,
                    ZIndex             = 5,
                    Parent             = innerFrame,
                })
            end

            -- ════════════════════════════════
            --  DIVIDER
            -- ════════════════════════════════
            function sec:AddDivider()
                Create("Frame", {
                    Size             = UDim2.new(1, 0, 0, 1),
                    BackgroundColor3 = T.Divider,
                    BorderSizePixel  = 0,
                    ZIndex           = 5,
                    Parent           = innerFrame,
                })
            end

            return sec
        end -- AddSection

        return tab
    end -- AddTab

    function win:Notify(c) SS.Notify(SS, c) end

    -- Key system
    if cfg.KeySystem and cfg.KeyConfig then
        MainWindow.Visible = false
        BuildKeySystem(cfg.KeyConfig, function()
            MainWindow.Visible = true
            SS:Notify({ Title = "SkidSoft", Desc = "Erfolgreich authentifiziert!", Type = "success", Duration = 3 })
        end)
    end

    return win
end

