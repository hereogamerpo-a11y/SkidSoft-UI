        Size               = UDim2.new(1, -16, 1, 0),
        Position           = UDim2.fromOffset(8, 0),
        BackgroundTransparency = 1,
        PlaceholderText    = "SS-XXXX-XXXX-XXXX-XXXX",
        PlaceholderColor3  = T.TextDark,
        Text               = "",
        Font               = Enum.Font.Code,
        TextSize           = 13,
        TextColor3         = T.Text,
        ClearTextOnFocus   = false,
        ZIndex             = 23,
        Parent             = inputBG,
    })
    keyInput.Focused:Connect(function()   Tween(inputStroke, { Color = T.Accent }, 0.15) end)
    keyInput.FocusLost:Connect(function() Tween(inputStroke, { Color = T.Stroke }, 0.15) end)

    -- Status
    local statusLbl = Create("TextLabel", {
        Size               = UDim2.new(1, 0, 0, 14),
        Position           = UDim2.fromOffset(0, 178),
        BackgroundTransparency = 1,
        Text               = "",
        Font               = Enum.Font.Gotham,
        TextSize           = 11,
        TextColor3         = T.Danger,
        TextXAlignment     = Enum.TextXAlignment.Center,
        ZIndex             = 22,
        Parent             = panel,
    })

